# www → apex redirect
https://www.pyxora.app/*  https://pyxora.app/:splat  301

# ============ BLOCK DEV/INTERNAL FILES FROM WEB ACCESS ============
# Cloudflare Pages auto-excludes dotfolders from deployment.
# All dev files (.mjs tests, package.json, docs) are under dotfolders:
#   .docs/    — SITE.md, CLAUDE.md (internal docs)
#   .tests/   — test.mjs, audit.mjs, gen-og.mjs, package.json (Playwright)
#
# Explicit rules below are backup-only in case dotfile exclusion changes.

/.docs/*             /404.html  404
/.tests/*            /404.html  404
/.env                /404.html  404
/.env.*              /404.html  404
/.gitignore          /404.html  404

# Subdomain placeholders for future use
# /arcade/*   https://arcade.pyxora.app/:splat  302
# /lab/*      https://lab.pyxora.app/:splat     302
